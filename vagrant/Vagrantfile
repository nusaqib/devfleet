# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Data-driven multi-machine Vagrantfile. The fleet is described in machines.yaml;
# this file just realizes it. `vagrant up` boots all; `vagrant up ubuntu` boots one.

require "yaml"

config_path = File.join(File.dirname(__FILE__), "machines.yaml")
cfg         = YAML.load_file(config_path)
defaults    = cfg.fetch("defaults", {})

# Provider chosen on THIS command line (e.g. `up --provider=libvirt`), if any.
CLI_PROVIDER = ARGV.join(" ")[/--provider[= ]([\w]+)/, 1]

# The provider a machine was ALREADY created with, read from Vagrant's state dir
# (.vagrant/machines/<name>/<provider>/). This is what makes plain `vagrant ssh`
# / `halt` / `provision` pick the right synced-folder type for an existing VM,
# without needing --provider or VAGRANT_DEFAULT_PROVIDER on every command.
def created_provider(name)
  base = File.join(File.dirname(__FILE__), ".vagrant", "machines", name.to_s)
  return nil unless File.directory?(base)
  # A provider dir counts only if it holds an `id` file (a real created machine);
  # empty leftover dirs from a destroyed/other provider are ignored.
  Dir.entries(base).find do |e|
    !e.start_with?(".") && File.file?(File.join(base, e, "id"))
  end
end

# Resolve the effective provider for a machine: explicit CLI flag wins, then the
# already-created provider, then VAGRANT_DEFAULT_PROVIDER, then virtualbox.
def resolve_provider(name)
  CLI_PROVIDER || created_provider(name) || ENV["VAGRANT_DEFAULT_PROVIDER"] || "virtualbox"
end

Vagrant.configure("2") do |config|
  cfg.fetch("machines").each do |m|
    config.vm.define m["name"] do |node|
      provider = resolve_provider(m["name"])
      node.vm.box      = m["box"]
      node.vm.hostname = "devfleet-#{m['name']}"
      # Pin a published box version if machines.yaml specifies one.
      node.vm.box_version = m["box_version"] if m["box_version"]

      # Forward SSH to a stable per-machine port for hand-run Ansible/debugging.
      node.vm.network "forwarded_port",
        guest: 22, host: m["ssh_port"], id: "ssh", auto_correct: true

      cpus   = m.fetch("cpus", defaults["cpus"])
      memory = m.fetch("memory", defaults["memory"])
      gui    = m.fetch("gui", defaults.fetch("gui", false))

      node.vm.provider "virtualbox" do |vb|
        vb.name   = "devfleet-#{m['name']}"
        vb.cpus   = cpus
        vb.memory = memory

        # `gui: true` in machines.yaml shows the VM window and gives it enough
        # video memory for a desktop. (Needs Guest Additions for live resize.)
        if gui
          vb.gui = true
          vb.customize ["modifyvm", :id, "--vram", "128",
                        "--graphicscontroller", "vmsvga"]
        end
      end

      # libvirt/QEMU provider — only if the plugin is installed (else ignored).
      if Vagrant.has_plugin?("vagrant-libvirt")
        node.vm.provider "libvirt" do |lv|
          lv.cpus   = cpus
          lv.memory = memory
          lv.graphics_type = gui ? "spice" : "none"
          # Wire up the qemu guest agent channel so vagrant-libvirt can read the
          # guest IP via the agent (a second path besides the DHCP lease).
          lv.qemu_use_agent = true
        end
      end

      # Synced-folder mechanism. VirtualBox can use native "virtualbox" (vboxsf,
      # needs Guest Additions) per-OS from machines.yaml. libvirt has no vboxsf,
      # so it always uses rsync (works without any guest tooling). `provider` is
      # resolved per-machine (CLI flag / created state / env / default) so this is
      # correct for `vagrant ssh`/`halt` on an existing VM, not just `up`.
      sf_type = m.fetch("synced_folder_type", defaults.fetch("synced_folder_type", "rsync"))
      sf_type = "rsync" if provider == "libvirt"

      # The default /vagrant mount only works via vboxsf; enable it natively when
      # we have GA (virtualbox + type virtualbox), otherwise disable it.
      if sf_type == "virtualbox"
        node.vm.synced_folder ".", "/vagrant", type: "virtualbox"
      else
        node.vm.synced_folder ".", "/vagrant", disabled: true
      end

      # Ship the repo's ansible/ tree into the guest so ansible_local can run
      # the shared playbook, using whichever mechanism this OS supports.
      node.vm.synced_folder "../ansible", "/vagrant_ansible", type: sf_type

      # Run-time provisioning uses the SAME playbook Packer baked with.
      # `ansible_local` runs inside the guest, so the host needs no Ansible.
      # Per-machine `extra_vars` in machines.yaml are merged in, so a single
      # machine can opt into extra roles (e.g. devfleet_install_desktop: true)
      # without affecting the rest of the fleet.
      run_vars = { "devfleet_context" => "runtime" }
      run_vars.merge!(m["extra_vars"]) if m["extra_vars"]
      node.vm.provision "ansible_local" do |ansible|
        ansible.playbook          = "/vagrant_ansible/base.yml"
        ansible.provisioning_path = "/vagrant_ansible"
        ansible.extra_vars        = run_vars
      end
    end
  end
end
