# ansible-lint config for devfleet.
# We deliberately use ignore_errors on best-effort tasks (EPEL/timezone that may
# be absent in minimal images), so skip that rule rather than litter the code.
skip_list:
  - ignore-errors

# The generated Vagrant/Packer inventories aren't checked in; don't warn about
# name casing on include filenames (Debian.yml / RedHat.yml match os_family).
warn_list:
  - var-naming[no-role-prefix]

exclude_paths:
  - inventory/
  # Vendored EPICS roles from the upstream training-vm project — kept verbatim so
  # they track upstream; not linted to devfleet's standards (they use short module
  # names / templated task names). Our own roles (base, devtools) are still linted.
  - roles/m_base/
  - roles/m_asyn/
  - roles/m_autosave/
  - roles/m_sscan/
  - roles/m_calc/
  - roles/m_seq/
  - roles/m_stream/
